# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/richsave
# or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/richsave?retryWrites=true&w=majority

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Mapbox/Google Maps API for location features
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here
# or
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key-here
